# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Gault&Millau
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Assets / Images S3 ────────────────────────────────────────────────────────
# URL de base S3 : les champs thumbId de l'API sont concaténés après ce chemin
NEXT_PUBLIC_S3_BASE_URL=changeme
# URL de base pour SmartImage (assets Directus si encore utilisé)
NEXT_PUBLIC_ASSETS_URL=changeme

# ─── Mapbox ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=changeme

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis

# ─── Cache / Auth secrets ───────────────────────────────────────────────────────
API_TOKEN=changeme
CACHE_INVALIDATE_SECRET=changeme
REVALIDATE_SECRET=changeme
