# ═══════════════════════════════════════════════════════════════════════════

# ─── App (public, gravé dans le bundle au build) ───────────────────────────
NEXT_PUBLIC_SITE_NAME=Gault&Millau Maroc
NEXT_PUBLIC_SITE_URL=https://gaultmillau.ma

# ─── Backend API ───────────────────────────────────────────────────────────
# En prod : le NOM DE DOMAINE public de l'API (pas localhost)
NEXT_PUBLIC_API_URL=https://api.gaultmillau.ma
# Clé serveur d'accès au backend (header x-api-key) — À RÉGÉNÉRER
API_KEY=CHANGEME_API_KEY

# Token d'auth de la route admin /api/cache (header Authorization: Bearer)
API_TOKEN=CHANGEME_API_TOKEN

# ─── Images S3 (public) ────────────────────────────────────────────────────
NEXT_PUBLIC_S3_BASE_URL=https://assets-gaultmillau-maroc.s3.eu-west-par.io.cloud.ovh.net

# ─── Revalidation du cache (le backend appelle /api/revalidate avec ce secret) ─
REVALIDATE_SECRET=CHANGEME_REVALIDATE_SECRET

# ─── Cartes (optionnel — laisser vide si non utilisé) ──────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Redis (OPTIONNEL) ─────────────────────────────────────────────────────
# Utilisé UNIQUEMENT par la route admin /api/cache. Le site fonctionne sans.
# Si tu ne te sers pas de /api/cache, tu peux supprimer ces 2 lignes + le
# REDIS_URL du docker-compose.
REDIS_URL=redis://localhost:6379
CACHE_INVALIDATE_SECRET=CHANGEME_CACHE_SECRET
