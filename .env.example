# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Gault&Millau Maroc
NEXT_PUBLIC_SITE_URL=https://www.gaultmillau.ma

# ─── Backend API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Clé serveur d'accès au backend — NE JAMAIS committer la vraie valeur
API_KEY=changeme

# Token d'auth des routes internes /api/cache (header Authorization: Bearer)
API_TOKEN=changeme

# ─── Images S3 ─────────────────────────────────────────────────────────
NEXT_PUBLIC_S3_BASE_URL=https://assets-gaultmillau-maroc.s3.example.net

# ─── Cache / Revalidation ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REVALIDATE_SECRET=changeme
CACHE_INVALIDATE_SECRET=changeme

# ─── Cartes ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
