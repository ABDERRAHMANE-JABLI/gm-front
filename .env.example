# ─── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Gault&Millau Maroc
NEXT_PUBLIC_SITE_URL=https://www.gaultmillau.ma

# ─── Backend API ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Clé serveur d'accès au backend — NE JAMAIS committer la vraie valeur
API_KEY=changeme

# Token d'auth des routes internes /api/cache (header Authorization: Bearer)
API_TOKEN=changeme

# ─── Images S3 ─────────────────────────────────────────────────────────
NEXT_PUBLIC_S3_BASE_URL=https://assets-gaultmillau-maroc.s3.example.net

# ─── Cache / Revalidation ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REVALIDATE_SECRET=changeme

# ─── Cartes ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── SEO / Google Search Console ───────────────────────────────────────
# Le "content" de la balise <meta name="google-site-verification"> fournie
# par Search Console. Laisser vide si non utilisé.
GOOGLE_SITE_VERIFICATION=

# ─── reCAPTCHA v2 ("Je ne suis pas un robot") ──────────────────────────
# Clés depuis https://www.google.com/recaptcha/admin (type v2 checkbox).
# Les DEUX sont requises pour que les formulaires contact/order fonctionnent.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
